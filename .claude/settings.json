{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(git:*)",
      "Bash(npm:*)",
      "Bash(node:*)",
      "Bash(prettier:*)",
      "Bash(python3:*)",
      "Bash(python3 -m json.tool:*)",
      "Bash(sha256sum:*)",
      "Bash(shellcheck:*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "prettier --write . 2>/dev/null || true"
          }
        ]
      }
    ]
  }
}
