{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(git:*)",
      "Bash(npm:*)",
      "Bash(node:*)",
      "Bash(prettier:*)",
      "Bash(python3:*)",
      "Bash(python3 -m json.tool:*)",
      "Bash(sha256sum:*)",
      "Bash(shellcheck:*)",
      "Bash(bash scripts/log-mistake.sh:*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "prettier --write . 2>/dev/null || true"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'if [ \"${CLAUDE_TOOL_EXIT_CODE:-0}\" != \"0\" ]; then bash scripts/log-mistake.sh \"Bash command failed (exit ${CLAUDE_TOOL_EXIT_CODE}): ${CLAUDE_TOOL_INPUT}\" 2>/dev/null || true; fi'"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash scripts/log-mistake.sh \"\" 2>/dev/null || true"
          }
        ]
      }
    ]
  }
}
