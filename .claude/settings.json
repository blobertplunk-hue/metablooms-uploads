{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(git:*)",
      "Bash(npm:*)",
      "Bash(node:*)",
      "Bash(prettier:*)",
      "Bash(python3:*)",
      "Bash(sha256sum:*)",
      "Bash(shellcheck:*)",
      "Bash(bash scripts/bts-init.sh:*)",
      "Bash(bash scripts/bts-record.sh:*)",
      "Bash(bash scripts/bts-auto-record.sh:*)",
      "Bash(bash scripts/bts-finalize.sh:*)",
      "Bash(bash scripts/bts-gate.sh:*)",
      "Bash(bash scripts/bts-stop-scan.sh:*)",
      "Bash(bash scripts/log-mistake.sh:*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash scripts/bts-auto-record.sh"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash scripts/bts-gate.sh"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash scripts/bts-init.sh 2>/dev/null || true"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "prettier --write . 2>/dev/null || true"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'code=\"${CLAUDE_TOOL_EXIT_CODE:-0}\"; if [ \"$code\" != \"0\" ]; then bash scripts/log-mistake.sh \"Bash exited $code: ${CLAUDE_TOOL_INPUT:-unknown}\" 2>/dev/null || true; fi'"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash scripts/bts-finalize.sh 2>/dev/null || true"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash scripts/bts-stop-scan.sh 2>/dev/null || true"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'if ! git diff --quiet 2>/dev/null || ! git diff --cached --quiet 2>/dev/null; then echo \"[stop-hook] Uncommitted changes detected. Commit and push before ending session.\"; fi'"
          }
        ]
      }
    ]
  }
}
